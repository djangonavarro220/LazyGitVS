{
  "name": "lazygitvs",
  "displayName": "LazyGitVS",
  "description": "A lazygit-inspired, keyboard-first Git workflow in the VS Code SCM sidebar.",
  "version": "0.1.101",
  "preview": true,
  "publisher": "lazygitvs",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "lazygit",
    "source-control",
    "scm",
    "keyboard",
    "staging",
    "hunks"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:lazygitvs.openDashboard",
    "onCommand:lazygitvs.closeDashboard",
    "onCommand:lazygitvs.resetState",
    "onCommand:lazygitvs.dumpHealth",
    "onCommand:lazygitvs.helpCurrentPanel",
    "onCommand:lazygitvs.enterCurrentFileHunkMode",
    "onCommand:lazygitvs.changedFiles",
    "onCommand:lazygitvs.enterSelected",
    "onCommand:lazygitvs.editorHunkNext",
    "onCommand:lazygitvs.editorHunkPrev",
    "onCommand:lazygitvs.editorHunkToggle",
    "onCommand:lazygitvs.editorHunkEdit",
    "onCommand:lazygitvs.editorHunkToggleMode",
    "onCommand:lazygitvs.editorHunkToggleSide",
    "onCommand:lazygitvs.editorHunkDiscard",
    "onCommand:lazygitvs.editorHunkHelp",
    "onCommand:lazygitvs.editorHunkNoop",
    "onCommand:lazygitvs.editorHunkExit",
    "onView:lazygitvs.statusView",
    "onView:lazygitvs.filesView",
    "onView:lazygitvs.branchesView",
    "onView:lazygitvs.tagsView",
    "onView:lazygitvs.remotesView",
    "onView:lazygitvs.commitsView",
    "onView:lazygitvs.stashView",
    "onView:lazygitvs.conflictsView",
    "onCommand:lazygitvs.statusRecentRepos",
    "onCommand:lazygitvs.statusEnter",
    "onCommand:lazygitvs.focusPanel1",
    "onCommand:lazygitvs.focusPanel2",
    "onCommand:lazygitvs.focusPanel3",
    "onCommand:lazygitvs.focusPanel4",
    "onCommand:lazygitvs.focusPanel5",
    "onCommand:lazygitvs.focusPanel6",
    "onCommand:lazygitvs.focusPanel7",
    "onCommand:lazygitvs.focusPanel8"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lazygitvs.openDashboard",
        "title": "LazyGitVS: Focus SCM Sidebar"
      },
      {
        "command": "lazygitvs.closeDashboard",
        "title": "LazyGitVS: Close Sidebar"
      },
      {
        "command": "lazygitvs.resetState",
        "title": "LazyGitVS: Reset state"
      },
      {
        "command": "lazygitvs.dumpHealth",
        "title": "LazyGitVS: Dump health"
      },
      {
        "command": "lazygitvs.helpCurrentPanel",
        "title": "LazyGitVS: Help current panel"
      },
      {
        "command": "lazygitvs.enterCurrentFileHunkMode",
        "title": "LazyGitVS: Enter current file HUNK mode"
      },
      {
        "command": "lazygitvs.changedFiles",
        "title": "LazyGitVS: Changed Files"
      },
      {
        "command": "lazygitvs.enterSelected",
        "title": "LazyGitVS: Enter Selected Item"
      },
      {
        "command": "lazygitvs.editorHunkNext",
        "title": "LazyGitVS: Editor Hunk Next"
      },
      {
        "command": "lazygitvs.editorHunkPrev",
        "title": "LazyGitVS: Editor Hunk Previous"
      },
      {
        "command": "lazygitvs.editorHunkToggle",
        "title": "LazyGitVS: Editor Hunk Stage/Unstage"
      },
      {
        "command": "lazygitvs.editorHunkEdit",
        "title": "LazyGitVS: Editor Hunk Edit Mode"
      },
      {
        "command": "lazygitvs.editorHunkExit",
        "title": "LazyGitVS: Exit Editor Hunk Mode"
      },
      {
        "command": "lazygitvs.editorHunkToggleMode",
        "title": "LazyGitVS: Toggle Editor Hunk/Line Mode"
      },
      {
        "command": "lazygitvs.editorHunkToggleSide",
        "title": "LazyGitVS: Toggle Editor Staged/Unstaged Hunks"
      },
      {
        "command": "lazygitvs.editorHunkHelp",
        "title": "LazyGitVS: Editor Hunk Help"
      },
      {
        "command": "lazygitvs.editorHunkDiscard",
        "title": "LazyGitVS: Discard/Unstage Editor Hunk"
      },
      {
        "command": "lazygitvs.statusEnter",
        "title": "LazyGitVS: Select Status Repository"
      },
      {
        "command": "lazygitvs.focusPanel1",
        "title": "LazyGitVS: Focus 1 Status"
      },
      {
        "command": "lazygitvs.focusPanel2",
        "title": "LazyGitVS: Focus 2 Files"
      },
      {
        "command": "lazygitvs.focusPanel3",
        "title": "LazyGitVS: Focus 3 Branches"
      },
      {
        "command": "lazygitvs.focusPanel4",
        "title": "LazyGitVS: Focus 4 Commits"
      },
      {
        "command": "lazygitvs.focusPanel5",
        "title": "LazyGitVS: Focus 5 Stash"
      },
      {
        "command": "lazygitvs.focusPanel6",
        "title": "LazyGitVS: Focus 6 Conflicts"
      },
      {
        "command": "lazygitvs.focusPanel7",
        "title": "LazyGitVS: Focus 7 Tags"
      },
      {
        "command": "lazygitvs.focusPanel8",
        "title": "LazyGitVS: Focus 8 Remotes"
      }
    ],
    "views": {
      "scm": [
        {
          "id": "lazygitvs.statusView",
          "name": "1 Status",
          "when": "lazygitvs.statusViewVisible",
          "visibility": "hidden"
        },
        {
          "id": "lazygitvs.filesView",
          "name": "2 Files",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "lazygitvs.branchesView",
          "name": "3 Branches",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "lazygitvs.commitsView",
          "name": "4 Commits",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "lazygitvs.stashView",
          "name": "5 Stash",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "lazygitvs.conflictsView",
          "name": "6 Conflicts",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "lazygitvs.tagsView",
          "name": "7 Tags",
          "type": "webview",
          "visibility": "visible"
        },
        {
          "id": "lazygitvs.remotesView",
          "name": "8 Remotes",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "title": "LazyGitVS",
      "properties": {
        "lazygitvs.showStatusBarMode": {
          "type": "boolean",
          "default": false,
          "description": "Show LazyGitVS mode in the VS Code status bar. Off by default to avoid duplicate Vim/Neovim mode labels. The sidebar footer still follows lazygit gui.showBottomLine."
        },
        "lazygitvs.previewTabs": {
          "type": "string",
          "enum": [
            "single",
            "multiple"
          ],
          "default": "single",
          "description": "Controls LazyGitVS preview tabs. 'single' keeps one dynamic LazyGitVS: <file> viewer; 'multiple' preserves the old behavior of leaving each preview tab open."
        }
      }
    },
    "keybindings": [
      {
        "key": "down",
        "command": "lazygitvs.editorHunkNext",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "up",
        "command": "lazygitvs.editorHunkPrev",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "j",
        "command": "lazygitvs.editorHunkNext",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "k",
        "command": "lazygitvs.editorHunkPrev",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "space",
        "command": "lazygitvs.editorHunkToggle",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "escape",
        "command": "lazygitvs.editorHunkExit",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "q",
        "command": "lazygitvs.closeDashboard",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "a",
        "command": "lazygitvs.editorHunkToggleMode",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "tab",
        "command": "lazygitvs.editorHunkToggleSide",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "ctrl+i",
        "command": "lazygitvs.editorHunkToggleSide",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "d",
        "command": "lazygitvs.editorHunkDiscard",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "shift+/",
        "command": "lazygitvs.editorHunkHelp",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "shift+'",
        "command": "lazygitvs.editorHunkHelp",
        "when": "lazygitvs.editorHunkMode && editorTextFocus"
      },
      {
        "key": "e",
        "command": "lazygitvs.editorHunkEdit",
