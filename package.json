  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "check:release": "node scripts/check-release-consistency.js",
    "test": "npm run compile && node scripts/run-tests.js",
    "dogfood:ui": "node scripts/dogfood-ui.js",
    "dogfood:ui:no-vim": "LGVS_DOGFOOD_VARIANT=no-vim node scripts/dogfood-ui.js",
    "dogfood:ui:preview-tabs": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_FAST_PREVIEW_TABS=1 node scripts/dogfood-ui.js",
    "dogfood:ui:vim": "LGVS_DOGFOOD_VARIANT=vim node scripts/dogfood-ui.js",
    "dogfood:ui:vim-escape": "LGVS_DOGFOOD_VARIANT=vim LGVS_DOGFOOD_FAST_VIM_ESCAPE=1 node scripts/dogfood-ui.js",
    "build": "npm run compile && npm run package",
    "package": "LGVS_VSIX_OUT_DIR=../releases/LazyGitVS npm run package:vsix",
    "package:vsix": "node scripts/package-vsix.js",
    "package:dist": "LGVS_VSIX_OUT_DIR=dist npm run package:vsix",
    "package:local": "node scripts/package-vsix.js",
    "dogfood:ui:reset-state": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_FAST_RESET_STATE=1 node scripts/dogfood-ui.js",
    "dogfood:ui:command-palette": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_FAST_COMMAND_PALETTE=1 node scripts/dogfood-ui.js",
    "dogfood:ui:hunk-escape": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_FAST_HUNK_ESCAPE=1 node scripts/dogfood-ui.js",
    "dogfood:ui:deep-tree": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_DEEP_TREE=1 node scripts/dogfood-ui.js",
    "dogfood:ui:cramped": "LGVS_DOGFOOD_WINDOW_SIZE=900,260 npm run dogfood:ui",
    "dogfood:ui:edge-files": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_EDGE_FILES=1 node scripts/dogfood-ui.js",
    "coverage": "node scripts/run-coverage.js",
    "dogfood:coverage": "node scripts/dogfood-coverage.js",
    "dogfood:ui:binary-file": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_BINARY_FILE=1 node scripts/dogfood-ui.js",
    "dogfood:ui:large-repo": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_LARGE_REPO=1 node scripts/dogfood-ui.js",
    "dogfood:ui:dark-theme": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_FAST_THEME=dark LGVS_DOGFOOD_THEME=\"Default Dark Modern\" node scripts/dogfood-ui.js",
    "dogfood:ui:high-contrast": "LGVS_DOGFOOD_VARIANT=no-vim LGVS_DOGFOOD_FAST_THEME=high-contrast LGVS_DOGFOOD_THEME=\"Default High Contrast\" node scripts/dogfood-ui.js",
