      },
      {
        "key": "q",
        "command": "lazygitvs.closeDashboard",
        "when": "webviewId == 'lazygitvs.statusView' || webviewId == 'lazygitvs.filesView' || webviewId == 'lazygitvs.branchesView' || webviewId == 'lazygitvs.commitsView' || webviewId == 'lazygitvs.stashView' || webviewId == 'lazygitvs.conflictsView' || webviewId == 'lazygitvs.tagsView' || webviewId == 'lazygitvs.remotesView'"
      },
      {
        "key": "ctrl+alt+g",
        "command": "lazygitvs.openDashboard",
        "when": "!terminalFocus"
      },
      {
        "key": "1",
        "command": "lazygitvs.focusPanel1",
        "when": "focusedView == lazygitvs.statusView && !editorTextFocus"
      },
